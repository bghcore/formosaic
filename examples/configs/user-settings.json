{
  "version": 2,
  "fields": {
    "displayName": {
      "type": "Textbox",
      "label": "Display Name",
      "required": true,
      "placeholder": "How you appear to other users"
    },
    "language": {
      "type": "Dropdown",
      "label": "Language",
      "required": true,
      "defaultValue": "en",
      "options": [
        { "value": "en", "label": "English" },
        { "value": "es", "label": "Español" },
        { "value": "fr", "label": "Français" },
        { "value": "de", "label": "Deutsch" },
        { "value": "ja", "label": "日本語" }
      ]
    },
    "emailNotifications": {
      "type": "Toggle",
      "label": "Email Notifications",
      "defaultValue": true,
      "rules": [
        {
          "id": "show-digest-frequency",
          "when": { "field": "emailNotifications", "operator": "equals", "value": true },
          "then": {
            "fields": {
              "digestFrequency": { "hidden": false }
            }
          },
          "else": {
            "fields": {
              "digestFrequency": { "hidden": true }
            }
          }
        }
      ]
    },
    "digestFrequency": {
      "type": "Dropdown",
      "label": "Email Digest Frequency",
      "defaultValue": "daily",
      "options": [
        { "value": "realtime", "label": "Real-time (as events occur)" },
        { "value": "daily", "label": "Daily digest" },
        { "value": "weekly", "label": "Weekly digest" },
        { "value": "never", "label": "Never" }
      ]
    },
    "theme": {
      "type": "Dropdown",
      "label": "Theme",
      "required": true,
      "defaultValue": "system",
      "options": [
        { "value": "system", "label": "System Default" },
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" },
        { "value": "custom", "label": "Custom" }
      ],
      "rules": [
        {
          "id": "custom-theme-shows-pickers",
          "when": { "field": "theme", "operator": "equals", "value": "custom" },
          "then": {
            "fields": {
              "accentColor": { "hidden": false },
              "fontScale": { "hidden": false },
              "themePreview": { "hidden": false }
            }
          },
          "else": {
            "fields": {
              "accentColor": { "hidden": true },
              "fontScale": { "hidden": true },
              "themePreview": { "hidden": true }
            }
          }
        }
      ]
    },
    "accentColor": {
      "type": "ColorPicker",
      "label": "Accent Color",
      "hidden": true,
      "defaultValue": "#0078d4"
    },
    "fontScale": {
      "type": "Slider",
      "label": "Font Scale",
      "hidden": true,
      "defaultValue": 100,
      "config": {
        "min": 75,
        "max": 150,
        "step": 5,
        "marks": [
          { "value": 75, "label": "75%" },
          { "value": 100, "label": "100%" },
          { "value": 125, "label": "125%" },
          { "value": 150, "label": "150%" }
        ]
      }
    },
    "themePreview": {
      "type": "DynamicFragment",
      "label": "",
      "hidden": true,
      "config": {
        "html": "<div style='padding: 14px 16px; background: var(--formosaic-surface, #f5f5f5); border: 1px solid var(--formosaic-border, #ddd); border-radius: 6px; font-size: 14px; color: var(--formosaic-text, #333);'><strong>Theme Preview</strong><br/><span style='color: var(--formosaic-text-secondary, #666);'>Your accent color and font scale changes will appear here when the form is rendered with your adapter.</span></div>"
      }
    },
    "twoFactorAuth": {
      "type": "Toggle",
      "label": "Two-Factor Authentication",
      "defaultValue": false,
      "rules": [
        {
          "id": "2fa-shows-method",
          "when": { "field": "twoFactorAuth", "operator": "equals", "value": true },
          "then": {
            "fields": {
              "twoFactorMethod": { "hidden": false, "required": true }
            }
          },
          "else": {
            "fields": {
              "twoFactorMethod": { "hidden": true, "required": false }
            }
          }
        }
      ]
    },
    "twoFactorMethod": {
      "type": "Dropdown",
      "label": "2FA Method",
      "hidden": true,
      "options": [
        { "value": "authenticator_app", "label": "Authenticator App (recommended)" },
        { "value": "sms", "label": "SMS Text Message" },
        { "value": "email", "label": "Email Code" }
      ]
    },
    "sessionTimeout": {
      "type": "Dropdown",
      "label": "Session Timeout",
      "defaultValue": "8h",
      "options": [
        { "value": "1h", "label": "1 hour" },
        { "value": "8h", "label": "8 hours" },
        { "value": "24h", "label": "24 hours" },
        { "value": "7d", "label": "7 days" },
        { "value": "never", "label": "Never (not recommended)" }
      ]
    },
    "dataExportFormat": {
      "type": "Dropdown",
      "label": "Data Export Format",
      "defaultValue": "csv",
      "options": [
        { "value": "csv", "label": "CSV" },
        { "value": "json", "label": "JSON" },
        { "value": "xlsx", "label": "Excel (XLSX)" }
      ]
    },
    "marketingOptIn": {
      "type": "Toggle",
      "label": "Receive product updates and announcements",
      "defaultValue": false
    }
  },
  "fieldOrder": [
    "displayName", "language",
    "emailNotifications", "digestFrequency",
    "theme", "accentColor", "fontScale", "themePreview",
    "twoFactorAuth", "twoFactorMethod",
    "sessionTimeout",
    "dataExportFormat",
    "marketingOptIn"
  ],
  "settings": {
    "manualSave": true
  }
}
