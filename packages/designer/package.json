{
  "name": "@form-eng/designer",
  "version": "1.0.1",
  "description": "Visual form builder for @form-eng/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/bghcore/form-engine.git",
    "directory": "packages/designer"
  },
  "homepage": "https://github.com/bghcore/form-engine#readme",
  "bugs": {
    "url": "https://github.com/bghcore/form-engine/issues"
  },
  "keywords": [
    "react",
    "forms",
    "form-builder",
    "form-designer",
    "dynamic-forms",
    "visual-builder",
    "drag-and-drop",
    "no-code",
    "low-code"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@form-eng/core": "^1.0.0"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@form-eng/core": "*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
