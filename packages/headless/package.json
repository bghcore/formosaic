{
  "name": "@form-eng/headless",
  "version": "1.0.0",
  "description": "Headless (unstyled) semantic HTML field components for @form-eng/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/bghcore/form-engine.git",
    "directory": "packages/headless"
  },
  "homepage": "https://github.com/bghcore/form-engine#readme",
  "bugs": {
    "url": "https://github.com/bghcore/form-engine/issues"
  },
  "keywords": [
    "react",
    "forms",
    "headless",
    "unstyled",
    "semantic-html",
    "dynamic-forms",
    "react-hook-form",
    "form-builder",
    "field-components",
    "tailwind",
    "business-forms"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup && node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0",
    "@form-eng/core": "^1.0.0"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "@form-eng/core": "*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
