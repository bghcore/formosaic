{
  "name": "@bghcore/dynamic-forms-core",
  "version": "1.2.1",
  "description": "Core business rules engine and form orchestration for dynamic React forms",
  "repository": {
    "type": "git",
    "url": "https://github.com/bghcore/dynamic-react-business-forms.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bghcore/dynamic-react-business-forms#readme",
  "bugs": {
    "url": "https://github.com/bghcore/dynamic-react-business-forms/issues"
  },
  "keywords": [
    "react",
    "forms",
    "business-rules",
    "dynamic-forms",
    "react-hook-form",
    "form-builder",
    "configuration-driven",
    "declarative-forms"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@types/react": "^19.2.14"
  }
}
