{
  "name": "@formosaic/core",
  "version": "1.3.1",
  "description": "Core business rules engine and form orchestration for dynamic React forms",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bghcore/formosaic.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bghcore/formosaic#readme",
  "bugs": {
    "url": "https://github.com/bghcore/formosaic/issues"
  },
  "keywords": [
    "formosaic",
    "react",
    "forms",
    "config-driven",
    "rules-engine",
    "typescript",
    "react-hook-form",
    "form-builder",
    "declarative",
    "validation",
    "wizard",
    "field-array",
    "computed-values",
    "json-schema",
    "rjsf",
    "zod",
    "i18n",
    "accessibility",
    "auto-save",
    "dynamic-forms",
    "business-rules",
    "conditional-logic",
    "field-dependencies",
    "form-validation",
    "async-validation",
    "conditional-fields",
    "form-state-management",
    "form-orchestration",
    "UI-agnostic"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapter-utils": {
      "types": "./dist/adapter-utils.d.ts",
      "import": "./dist/adapter-utils.mjs",
      "require": "./dist/adapter-utils.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.mjs",
      "require": "./dist/devtools.js"
    },
    "./rjsf": {
      "types": "./dist/rjsf.d.ts",
      "import": "./dist/rjsf.mjs",
      "require": "./dist/rjsf.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.mjs",
      "require": "./dist/zod.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "license": "MIT",
  "author": "bghcore (https://github.com/bghcore)",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0"
  },
  "devDependencies": {
    "@formosaic/antd": "*",
    "@formosaic/atlaskit": "*",
    "@formosaic/base-web": "*",
    "@formosaic/chakra": "*",
    "@formosaic/fluent": "*",
    "@formosaic/headless": "*",
    "@formosaic/heroui": "*",
    "@formosaic/mantine": "*",
    "@formosaic/mui": "*",
    "@formosaic/radix": "*",
    "@formosaic/react-aria": "*",
    "@testing-library/react": "^16.3.2",
    "@types/expr-eval": "^1.0.2",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "expr-eval": "^2.0.2"
  }
}
