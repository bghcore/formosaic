{
  "name": "@bghcore/dynamic-forms-core",
  "version": "0.1.0",
  "description": "Core business rules engine and form orchestration for dynamic React forms",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@types/react": "^19.2.14"
  }
}
