{
  "name": "@form-eng/core",
  "version": "1.0.1",
  "description": "Core business rules engine and form orchestration for dynamic React forms",
  "repository": {
    "type": "git",
    "url": "https://github.com/bghcore/form-engine.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bghcore/form-engine#readme",
  "bugs": {
    "url": "https://github.com/bghcore/form-engine/issues"
  },
  "keywords": [
    "react",
    "forms",
    "dynamic-forms",
    "business-rules",
    "form-builder",
    "react-hook-form",
    "configuration-driven",
    "declarative-forms",
    "json-forms",
    "schema-forms",
    "form-engine",
    "conditional-logic",
    "field-dependencies",
    "form-validation",
    "async-validation",
    "wizard-form",
    "multi-step-form",
    "field-array",
    "i18n-forms",
    "zod",
    "json-schema"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@types/react": "^19.2.14"
  }
}
